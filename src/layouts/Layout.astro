---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
    description?: string;
    siteName?: string;
}

const {
    title,
    description = "HAIPS@COLM 2026: 2nd Workshop on Human-Centered Privacy and Security for Language Models",
    siteName = "HAIPS@COLM 2026",
} = Astro.props;
const pageTitle = `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
        <!-- <link rel="stylesheet" href="/styles/global.css" /> -->
    </head>
    <body>
        <Header />
        <main>
            <slot />
        </main>
        <Footer />
        <style is:global>
            :root {
                /* Primary palette — restrained academic blue */
                --accent: #3498db;
                --accent-light: #ecf0f1;
                --accent-dark: #2980b9;
                --accent-tint: #e3f1fa;

                /* Secondary accent — warm amber for sociotechnical/human warmth,
                   used sparingly on the workshop-date emphasis, pull-quote, and
                   the second stop of the section-heading underline. */
                --accent-warm: #d97706;
                --accent-warm-soft: #fef3e2;

                --text-primary: #2c3e50;
                --text-secondary: #56697a; /* Bumped for ~4.7:1 AA contrast on bg-primary */
                --text-muted: #7f8c8d;

                --bg-primary: #f1f4f7;
                --bg-secondary: #f8f9fa;
                --bg-card: #ffffff;
                --border-color: #e0e0e0;

                --link-color: var(--accent-dark);
                --link-hover-color: var(--accent);

                --radius-sm: 6px;
                --radius-md: 10px;
                --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.04);
                --shadow-md: 0 2px 10px rgba(15, 23, 42, 0.06);
            }
            html {
                font-family: system-ui, sans-serif;
                background: var(--bg-primary);
                color: var(--text-primary);
                line-height: 1.6;
                scroll-behavior: smooth;
                /* --header-height is set at runtime by Header.astro; the fallback
                   covers the brief moment before the script runs. */
                scroll-padding-top: calc(var(--header-height, 130px) + 1rem);
            }
            body {
                margin: 0;
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }
            main {
                flex-grow: 1;
                max-width: 800px;
                margin: calc(var(--header-height, 130px) + 1.5rem) auto 2rem auto;
                padding: 0 1rem;
                width: 90%;
            }
            h1, h2, h3, h4 {
                color: var(--accent-dark);
                margin-top: 2em;
                margin-bottom: 0.8em;
                line-height: 1.3;
            }
             h1 {
                font-size: 2.2rem;
                border-bottom: 2px solid var(--accent-light);
                padding-bottom: 0.3em;
            }
             h2 {
                font-size: 1.8rem;
                letter-spacing: -0.005em;
             }
             h3 {
                 font-size: 1.35rem;
                 color: var(--text-primary);
             }
            a {
                color: var(--link-color);
                text-decoration: none;
                transition: color 0.15s ease;
            }
            a:hover {
                color: var(--link-hover-color);
                text-decoration: underline;
            }
            /* Accessible keyboard focus ring on every interactive element. */
            a:focus-visible,
            button:focus-visible,
            summary:focus-visible {
                outline: 2px solid var(--accent);
                outline-offset: 3px;
                border-radius: 3px;
                text-decoration: none;
            }
            p, ul, ol, table, blockquote {
                margin-bottom: 1em;
            }
            ul {
                list-style: disc;
                padding-left: 1.5em;
            }
             ol {
                list-style: decimal;
                padding-left: 1.5em;
            }
            code {
                font-family: monospace;
                background-color: var(--accent-light);
                padding: 0.2em 0.4em;
                border-radius: 3px;
                font-size: 0.9em;
            }
            pre {
                background-color: var(--bg-secondary);
                padding: 1em;
                border-radius: 5px;
                overflow-x: auto;
                border: 1px solid var(--border-color);
            }
            pre code {
                 background-color: transparent;
                 padding: 0;
            }
            blockquote {
                border-left: 4px solid var(--accent);
                padding-left: 1em;
                margin-left: 0;
                font-style: italic;
                color: var(--text-secondary);
            }
            table {
                border-collapse: collapse;
                width: 100%;
                margin-bottom: 1.5rem;
                border: 1px solid var(--border-color);
            }
            th, td {
                border: 1px solid var(--border-color);
                padding: 0.75rem;
                text-align: left;
            }
            th {
                background-color: var(--bg-secondary);
                font-weight: bold;
            }
            .container {
                 max-width: 800px;
                 margin: 0 auto;
                 padding: 0 1rem;
            }

        </style>
    </body>
</html> 
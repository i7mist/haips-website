---
// src/components/Header.astro
const navLinks = [
    { href: '/#', text: 'Home' },
    { href: '/#dates', text: 'Key Dates' },
    { href: '/#speakers', text: 'Speakers' },
    { href: '/#cfp', text: 'Call for Papers' },
    { href: '/#organization', text: 'Organizers' },
    { href: '/haips2025', text: 'Archive (2025)' },
];
---

<header>
    <div class="container">
        <div class="logo" aria-hidden="true">
            <a href="/#" tabindex="-1">
                <h1>HAIPS@COLM 2026</h1>
                <p class="subtitle">2nd Workshop on Human-Centered Privacy and Security for Language Models</p>
            </a>
        </div>
        <nav>
            <ul>
                {navLinks.map(link => (
                    <li><a href={link.href}>{link.text}</a></li>
                ))}
            </ul>
        </nav>
    </div>
</header>

<script is:inline>
    (function () {
        const header = document.querySelector('header');
        if (!header) return;
        const logo = header.querySelector('.logo');
        const logoLink = logo ? logo.querySelector('a') : null;

        // ── Scrolled shadow / glass effect ─────────────────────────
        const handleScroll = () => {
            header.classList.toggle('scrolled', window.scrollY > 10);
        };
        handleScroll();
        window.addEventListener('scroll', handleScroll, { passive: true });

        // ── Publish live header height so <main> reserves enough space.
        const updateHeaderHeight = () => {
            document.documentElement.style.setProperty(
                '--header-height',
                `${header.offsetHeight}px`,
            );
        };
        updateHeaderHeight();
        window.addEventListener('resize', updateHeaderHeight);
        if (typeof ResizeObserver !== 'undefined') {
            new ResizeObserver(updateHeaderHeight).observe(header);
        }

        // ── Reveal the workshop title in the header once the hero scrolls
        //    out of view. Restores when the hero comes back into view.
        const setTitleVisible = (visible) => {
            header.classList.toggle('show-title', visible);
            if (logo) {
                logo.setAttribute('aria-hidden', String(!visible));
            }
            if (logoLink) {
                // Avoid trapping keyboard focus on the hidden logo link.
                logoLink.setAttribute('tabindex', visible ? '0' : '-1');
            }
        };

        // Start hidden. We can't look up the hero yet because the parser
        // is still inside <header> — <main> hasn't been parsed, so the
        // hero element doesn't exist in the DOM yet. Wait until DOM ready.
        setTitleVisible(false);

        const initHeroObserver = () => {
            const hero = document.querySelector('.hero, .hero-image');
            if (!hero || typeof IntersectionObserver === 'undefined') {
                // Pages without a hero (or unsupported browsers): show title.
                setTitleVisible(true);
                return;
            }
            const observer = new IntersectionObserver(
                (entries) => {
                    const entry = entries[0];
                    // Only show the title once the hero is fully ABOVE the
                    // viewport (i.e. scrolled past), not when it's still
                    // below (initial load).
                    const scrolledPast = entry.boundingClientRect.bottom <= 0;
                    setTitleVisible(scrolledPast);
                },
                { threshold: 0 },
            );
            observer.observe(hero);
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initHeroObserver);
        } else {
            initHeroObserver();
        }
    })();
</script>

<style>
    header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
        background-color: var(--bg-primary);
        padding: 1rem 0;
        border-bottom: 1px solid transparent;
        transition:
            background-color 0.3s ease,
            border-color 0.3s ease,
            box-shadow 0.3s ease,
            backdrop-filter 0.3s ease;
    }

    header.scrolled {
        background-color: rgba(241, 244, 247, 0.82);
        border-bottom-color: var(--border-color);
        box-shadow: 0 4px 18px rgba(15, 23, 42, 0.06);
        backdrop-filter: saturate(140%) blur(10px);
        -webkit-backdrop-filter: saturate(140%) blur(10px);
    }

    .container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    /* ── Logo: hidden by default, slides+fades in when scrolled past hero ── */
    .logo {
        opacity: 0;
        transform: translateY(-6px);
        max-height: 0;
        max-width: 100%;
        overflow: hidden;
        visibility: hidden;
        transition:
            opacity 0.3s ease,
            transform 0.35s ease,
            max-height 0.35s ease,
            margin 0.35s ease,
            visibility 0s linear 0.35s;
    }
    header.show-title .logo {
        opacity: 1;
        transform: translateY(0);
        max-height: 180px;
        visibility: visible;
        transition:
            opacity 0.3s ease,
            transform 0.35s ease,
            max-height 0.35s ease,
            margin 0.35s ease,
            visibility 0s linear 0s;
    }

    .logo a {
        text-decoration: none;
        color: inherit;
        display: inline-block;
    }
    .logo h1 {
        margin: 0;
        font-size: 1.45rem;
        line-height: 1.15;
        color: var(--accent-dark);
        border-bottom: none;
        padding-bottom: 0;
        letter-spacing: -0.005em;
    }
    .logo .subtitle {
        margin: 0.1rem 0 0 0;
        font-size: 0.82rem;
        color: var(--text-secondary);
        line-height: 1.3;
    }

    /* ── Nav ───────────────────────────────────────────────────── */
    nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 1.4rem;
        flex-wrap: wrap;
        align-items: center;
    }
    nav li {
        margin: 0;
    }
    nav a {
        text-decoration: none;
        color: var(--text-primary);
        font-weight: 500;
        font-size: 0.95rem;
        padding: 0.4rem 0;
        position: relative;
        transition: color 0.18s ease;
    }
    nav a:hover {
        color: var(--accent-dark);
    }
    nav a::after {
        content: '';
        position: absolute;
        height: 2px;
        bottom: -2px;
        left: 0;
        right: 0;
        background-color: var(--accent);
        transform: scaleX(0);
        transform-origin: bottom right;
        transition: transform 0.25s ease-out;
    }
    nav a:hover::after {
        transform: scaleX(1);
        transform-origin: bottom left;
    }

    /* ── Responsive ────────────────────────────────────────────── */
    @media (max-width: 700px) {
        .container {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.6rem;
        }
        header.show-title .logo {
            max-height: 200px;
        }
        nav ul {
            gap: 1rem;
            row-gap: 0.5rem;
        }
        .logo h1 {
            font-size: 1.25rem;
        }
        .logo .subtitle {
            font-size: 0.78rem;
        }
    }

    /* Respect users who prefer reduced motion. */
    @media (prefers-reduced-motion: reduce) {
        .logo,
        header.show-title .logo {
            transition: opacity 0.15s linear, visibility 0s;
            transform: none;
        }
        header {
            transition: none;
        }
    }
</style>

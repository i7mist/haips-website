---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { organizers } from '../data/organizers2026.js';

type Speaker = {
    name: string;
    affiliation: string;
    website?: string;
    profilePic?: string;
};

const speakers: Speaker[] = [
    {
        name: 'Helen Nissenbaum',
        affiliation: 'Cornell Tech',
        website: 'https://nissenbaum.tech.cornell.edu/',
        profilePic: '/speaker-helen-nissenbaum.jpg',
    },
    {
        name: 'Ruoxi Jia',
        affiliation: 'Virginia Tech',
        website: 'https://ruoxijia.info/',
        profilePic: '/speaker-ruoxi-jia.jpg',
    },
    {
        name: 'Maarten Sap',
        affiliation: 'Carnegie Mellon University',
        website: 'https://maartensap.com/',
        profilePic: '/speaker-maarten-sap.jpg',
    },
    {
        name: 'Nina Taft',
        affiliation: 'Google',
        website: 'https://research.google/people/nina-taft/',
        profilePic: '/speaker-nina-taft.png',
    },
    {
        name: 'Florian Tramèr',
        affiliation: 'ETH Zurich',
        website: 'https://floriantramer.com/',
        profilePic: '/speaker-florian-tramer.png',
    },
];

type ScheduleItem = { time: string; session: string };
const schedule: ScheduleItem[] = [
    { time: '9:00',  session: 'Opening remarks' },
    { time: '9:10',  session: 'Invited talks I (2 talks)' },
    { time: '10:05', session: 'Coffee + poster session' },
    { time: '10:35', session: 'Invited talks II (3 talks)' },
    { time: '12:00', session: 'Lunch' },
    { time: '13:30', session: 'Spotlight presentations' },
    { time: '14:15', session: 'Panel (all speakers)' },
    { time: '15:00', session: 'Coffee + poster session' },
    { time: '15:30', session: 'Unconference discussions' },
    { time: '16:30', session: 'Report-backs + closing' },
];
---

<Layout title="Home">

    <img src="/haips-banner.png" alt="HAIPS Workshop Banner" class="hero-image">

    <p>
        <strong>
            We are excited to announce the 2nd workshop on Human-Centered Privacy and Security for Language Models (HAIPS@COLM), co-located with <a href="https://colmweb.org/" target="_blank" rel="noopener noreferrer">COLM 2026</a> in San Francisco on October 9, 2026.
        </strong>
    </p>

    <p>
        Language models are rapidly becoming embedded in the interaction fabric of our society &mdash; as assistants, tutors, collaborators, and autonomous agents across domains from healthcare to software engineering to creative work. Their versatility makes them uniquely powerful but also uniquely hard to secure: privacy and security risks arise not just from model internals but from the rich, open-ended ways people interact with and through these systems. Humans sit at the center of these challenges &mdash; as victims of privacy violations and manipulation, as intentional or unintentional facilitators of risk, and as bystanders whose data is swept up without consent.
    </p>

    <p>
        HAIPS@COLM aims to bring a human-centered, interdisciplinary lens to LM privacy and security, building on the <a href="/haips2025">1st HAIPS Workshop</a> held at ACM CCS 2025. We aim to foster a two-way exchange between the COLM community and researchers in HCI, usable security, and policy &mdash; grounding human-centered approaches in what LMs actually do, and informing model design with how people actually experience them.
    </p>

    <section id="dates">
        <h2>Key Dates</h2>
        <ul class="styled-list">
            <li><strong>Submission Deadline:</strong> June 23, 2026</li>
            <li><strong>Notification of Acceptance:</strong> July 24, 2026</li>
            <li><strong>Camera-Ready Deadline:</strong> August 20, 2026</li>
            <li><strong>Workshop Date:</strong> October 9, 2026</li>
        </ul>
    </section>

    <section id="speakers">
        <h2>Invited Speakers</h2>
        <ul class="people-grid">
            {speakers.map(s => (
                <li class="person-card">
                    {s.profilePic ? (
                        <img src={s.profilePic} alt={`Profile photo of ${s.name}`} class="person-pic" />
                    ) : (
                        <div class="person-pic person-pic-placeholder"></div>
                    )}
                    <div class="person-name">
                        {s.website ? (
                            <a href={s.website} target="_blank" rel="noopener noreferrer">{s.name}</a>
                        ) : (
                            <span>{s.name}</span>
                        )}
                    </div>
                    <div class="person-affil">{s.affiliation}</div>
                </li>
            ))}
        </ul>
    </section>

    <section id="cfp">
        <h2>Call for Submissions</h2>
        <p>
            We invite submissions on human-centered privacy and security for language models. Topics include, but are not limited to:
        </p>
        <ul>
            <li>Training data privacy and consent</li>
            <li>User disclosure and interaction privacy</li>
            <li>Agentic system risks (context leakage, prompt injection, human oversight)</li>
            <li>Inference and aggregation threats, and human-centered defenses</li>
            <li>LMs as human simulators (consent, representational harms, simulated users for auditing)</li>
            <li>Dark patterns, manipulation, and social engineering in or facilitated by LM systems</li>
            <li>LM-powered privacy/security tools and education</li>
            <li>Practitioner risks (insecure AI-generated code, concealed AI use)</li>
            <li>Policy and governance for LM privacy and security</li>
            <li>Societal impacts, including tensions with fairness and transparency</li>
        </ul>

        <p>We welcome both <strong>original research papers</strong> and <strong>position papers</strong>.</p>

        <h3>Submission Format</h3>
        <ul>
            <li><strong>Long papers:</strong> up to 8 pages, excluding references and appendices.</li>
            <li><strong>Short papers:</strong> up to 4 pages, excluding references and appendices.</li>
            <li>Submissions must use the <a href="https://colmweb.org/cfp.html" target="_blank" rel="noopener noreferrer">COLM format</a>.</li>
            <li>Accepted papers are <strong>non-archival</strong>, leaving authors free to submit revised versions to other venues.</li>
        </ul>

        <h3>Review Process</h3>
        <p>
            Review will be <strong>double-blind on OpenReview</strong>, with at least two reviewers per paper. Conflicts of interest will be managed through OpenReview&rsquo;s COI detection and self-declared conflicts.
        </p>

        <h3>Awards</h3>
        <p>
            We aim to establish <strong>Best Paper</strong> and <strong>Best Student Paper</strong> awards to highlight outstanding work, with particular attention to early-career researchers.
        </p>

        <p><em>The OpenReview submission link will be announced closer to the deadline. Please check back for updates.</em></p>
    </section>

    <section id="program">
        <h2>Tentative Schedule</h2>
        <table class="program-table">
            <thead>
                <tr><th>Time</th><th>Session</th></tr>
            </thead>
            <tbody>
                {schedule.map(item => (
                    <tr><td>{item.time}</td><td>{item.session}</td></tr>
                ))}
            </tbody>
        </table>
    </section>

    <section id="organization">
        <h2>Organizers</h2>
        <ul class="people-grid">
            {organizers.chairs.map(chair => (
                <li class="person-card">
                    {chair.profilePic ? (
                        <img src={chair.profilePic} alt={`Profile photo of ${chair.name}`} class="person-pic" />
                    ) : (
                        <div class="person-pic person-pic-placeholder"></div>
                    )}
                    <div class="person-name">
                        {chair.website && chair.website !== '#' ? (
                            <a href={chair.website} target="_blank" rel="noopener noreferrer">{chair.name}</a>
                        ) : (
                            <span>{chair.name}</span>
                        )}
                    </div>
                    <div class="person-affil">{chair.affiliation}</div>
                </li>
            ))}
        </ul>
    </section>

</Layout>

<style>
    .hero-image {
        width: 100%;
        object-fit: cover;
        margin-bottom: 1rem;
        border-radius: 8px;
        background-color: var(--bg-secondary);
    }
    section {
        margin-bottom: 3rem;
        padding-top: 1rem;
    }
    section h2 {
        margin-top: 0;
        border-bottom: 2px solid var(--accent-light);
        padding-bottom: 0.4rem;
        display: inline-block;
    }
    section h3 {
        margin-top: 2.5rem;
    }
    .styled-list {
        list-style: none;
        padding-left: 0;
    }
    .styled-list li {
        margin-bottom: 0.5rem;
        padding-left: 1.2em;
        position: relative;
    }
    .styled-list li::before {
        content: '\25AA';
        color: var(--accent);
        position: absolute;
        left: 0;
        top: 1px;
        font-size: 0.8em;
    }

    /* Shared people grid (speakers + organizers) */
    .people-grid {
        list-style: none;
        padding-left: 0;
        margin-top: 1.5rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1.5rem;
    }
    .person-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 0.25rem;
    }
    .person-pic,
    .person-pic-placeholder {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        object-fit: cover;
        background-color: var(--accent-light);
        margin-bottom: 0.85rem;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    }
    .person-name {
        font-size: 1.02rem;
        font-weight: 600;
        line-height: 1.3;
        color: var(--text-primary);
    }
    .person-name a {
        color: var(--text-primary);
    }
    .person-name a:hover {
        color: var(--accent);
        text-decoration: none;
    }
    .person-affil {
        margin-top: 0.2rem;
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.3;
    }

    /* Schedule */
    #program .program-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }
    #program th,
    #program td {
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--border-color);
        text-align: left;
    }
    #program thead th {
        background: var(--accent-light);
        color: var(--accent-dark);
    }
    #program tbody tr:nth-child(even) {
        background: var(--bg-secondary);
    }

    /* CFP list styling */
    #cfp ul,
    #cfp ol {
        margin-left: 1.5em;
    }
    #cfp ul {
        list-style: disc;
    }
    #cfp ol {
        list-style: decimal;
    }
</style>

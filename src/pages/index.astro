---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { organizers } from '../data/organizers2026.js';

type Speaker = {
    name: string;
    affiliation: string;
    website?: string;
    profilePic?: string;
};

const speakers: Speaker[] = [
    {
        name: 'Helen Nissenbaum',
        affiliation: 'Cornell Tech',
        website: 'https://nissenbaum.tech.cornell.edu/',
        profilePic: '/speaker-helen-nissenbaum.jpg',
    },
    {
        name: 'Ruoxi Jia',
        affiliation: 'Virginia Tech',
        website: 'https://ruoxijia.net',
        profilePic: '/speaker-ruoxi-jia.jpg',
    },
    {
        name: 'Maarten Sap',
        affiliation: 'Carnegie Mellon University',
        website: 'https://maartensap.com/',
        profilePic: '/speaker-maarten-sap.jpg',
    },
    {
        name: 'Nina Taft',
        affiliation: 'Google',
        website: 'https://research.google/people/nina-taft/',
        profilePic: '/speaker-nina-taft.png',
    },
    {
        name: 'Florian Tramèr',
        affiliation: 'ETH Zurich',
        website: 'https://floriantramer.com/',
        profilePic: '/speaker-florian-tramer.png',
    },
];

---

<Layout title="Home">

    <section class="hero" aria-labelledby="hero-title">
        <div class="hero-motif" aria-hidden="true"></div>
        <div class="hero-content">
            <p class="hero-eyebrow">2nd Workshop · HAIPS@COLM 2026</p>
            <h1 id="hero-title" class="hero-title">Human-Centered Privacy and Security for <span class="hero-accent">Language Models</span></h1>
            <p class="hero-tagline">Studying, critiquing, and building privacy and security protections for language models used by real people.</p>
            <p class="hero-meta">
                <span>October 9, 2026</span>
                <span aria-hidden="true" class="hero-sep">·</span>
                <span>San Francisco</span>
                <span aria-hidden="true" class="hero-sep">·</span>
                <span>Co-located with <a href="https://colmweb.org/" target="_blank" rel="noopener noreferrer">COLM 2026</a></span>
            </p>
            <div class="hero-cta">
                <a href="https://openreview.net/group?id=colmweb.org/COLM/2026/Workshop/HAIPS" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Submit Paper</a>
                <a href="#cfp" class="btn btn-secondary">Call for Papers</a>
                <a href="#dates" class="btn btn-secondary">Key Dates</a>
            </div>
        </div>
    </section>

    <p>
        Language models are rapidly becoming embedded in the interaction fabric of our society &mdash; as assistants, tutors, collaborators, and autonomous agents across domains from healthcare to software engineering to creative work. Their versatility makes them uniquely powerful but also uniquely hard to secure: privacy and security risks arise not just from model internals but from the rich, open-ended ways people interact with and through these systems.
    </p>

    <blockquote class="pull-quote">
        Humans sit at the center of these challenges &mdash; as victims of privacy violations and manipulation, as intentional or unintentional facilitators of risk, and as bystanders whose data is swept up without consent.
    </blockquote>

    <p>
        HAIPS@COLM aims to bring a human-centered, interdisciplinary lens to LM privacy and security, building on the <a href="/haips2025">1st HAIPS Workshop</a> held at ACM CCS 2025. We aim to foster a two-way exchange between the COLM community and researchers in HCI, usable security, and policy &mdash; grounding human-centered approaches in what LMs actually do, and informing model design with how people actually experience them.
    </p>

    <section id="dates">
        <h2>Key Dates</h2>
        <ol class="dates-grid">
            <li class="date-card">
                <span class="date-label">Submission Deadline</span>
                <time class="date-value" datetime="2026-06-23">June 23, 2026</time>
            </li>
            <li class="date-card">
                <span class="date-label">Notification of Acceptance</span>
                <time class="date-value" datetime="2026-07-24">July 24, 2026</time>
            </li>
            <li class="date-card">
                <span class="date-label">Camera-Ready Deadline</span>
                <time class="date-value" datetime="2026-08-20">August 20, 2026</time>
            </li>
            <li class="date-card date-card-workshop">
                <span class="date-label">Workshop <span class="date-pill" aria-hidden="true">Event Day</span></span>
                <time class="date-value" datetime="2026-10-09">October 9, 2026</time>
            </li>
        </ol>
    </section>

    <section id="speakers">
        <h2>Invited Speakers</h2>
        <ul class="people-grid">
            {speakers.map(s => (
                <li class="person-card">
                    {s.profilePic ? (
                        <img src={s.profilePic} alt={`Profile photo of ${s.name}`} class="person-pic" />
                    ) : (
                        <div class="person-pic person-pic-placeholder"></div>
                    )}
                    <div class="person-name">
                        {s.website ? (
                            <a href={s.website} target="_blank" rel="noopener noreferrer">{s.name}</a>
                        ) : (
                            <span>{s.name}</span>
                        )}
                    </div>
                    <div class="person-affil">{s.affiliation}</div>
                </li>
            ))}
        </ul>
    </section>

    <section id="cfp">
        <h2>Call for Papers</h2>
        <p>
            HAIPS@COLM invites work that studies, critiques, and builds privacy, security, and safety protections for language models and agentic AI systems as technologies used by real people. We welcome submissions from both the core language-modeling community and the HCI, usable security, privacy, and policy communities.
        </p>
        <p>
            We especially encourage work that connects technical mechanisms with human needs, including systems, tools, infrastructure, empirical studies, benchmarks, design work, policy analysis, audits, and position papers. Human-centered work need not always include a user study; technical papers are welcome when they clearly articulate the people, workflows, communities, or deployment contexts their work is intended to benefit.
        </p>

        <h3>Topics of Interest</h3>
        <p>Topics of interest include, but are not limited to:</p>
        <ul>
            <li>Human expectations, consent, and control over data used in LM systems</li>
            <li>Privacy- and security-preserving LM infrastructure for protecting people and institutions in real-world deployment contexts</li>
            <li>User-facing protections that help people understand and prevent LM privacy and security risks</li>
            <li>Human oversight, delegation, and accountability in agentic, personalized, and tool-using LM systems</li>
            <li>Evaluation and benchmarking of LM and LM-system privacy, security, and safety through a human lens</li>
            <li>Human impacts of adversarial LM-enabled privacy and security threats</li>
            <li>User vulnerability, manipulation, deception, and dark patterns involving language models</li>
            <li>Effects of language models used as simulated users, evaluators, auditors, or research participants</li>
            <li>LM-powered tools that support privacy, security, safety, and human agency</li>
            <li>Developer and organizational practices, risks, and responsibilities in LM design and deployment</li>
            <li>Human-centered policy and governance for LM privacy, security, and safety</li>
        </ul>

        <p>
            Our goal is to bring together researchers who identify emerging risks, understand their human and societal implications, and build practical protections that make language-model systems safer, more private, more secure, and more accountable in real-world use.
        </p>

        <h3>Submission Format</h3>
        <ul>
            <li><strong>Long papers:</strong> up to 9 pages, excluding references and appendices.</li>
            <li><strong>Short papers:</strong> up to 4 pages, excluding references and appendices.</li>
            <li>Submissions may use the <a href="https://colmweb.org/cfp.html" target="_blank" rel="noopener noreferrer">COLM</a>, <a href="https://www.overleaf.com/latex/templates/formatting-instructions-for-neurips-2026/bjdwqfdkyftc" target="_blank" rel="noopener noreferrer">NeurIPS</a>, or <a href="https://github.com/acl-org/acl-style-files" target="_blank" rel="noopener noreferrer">EMNLP</a> format.</li>
            <li>Accepted papers are <strong>non-archival</strong>, leaving authors free to submit revised versions to other venues.</li>
        </ul>

        <h3>Review Process</h3>
        <p>
            Review will be <strong>double-blind on OpenReview</strong>, with at least two reviewers per paper. Conflicts of interest will be managed through OpenReview&rsquo;s COI detection and self-declared conflicts.
        </p>

        <h3>Awards</h3>
        <p>
            We aim to establish <strong>Best Paper</strong> and <strong>Best Student Paper</strong> awards to highlight outstanding work, with particular attention to early-career researchers.
        </p>

        <p>Submit your paper via OpenReview: <a href="https://openreview.net/group?id=colmweb.org/COLM/2026/Workshop/HAIPS" target="_blank" rel="noopener noreferrer">https://openreview.net/group?id=colmweb.org/COLM/2026/Workshop/HAIPS</a></p>
    </section>

    <section id="organization">
        <h2>Organizers</h2>
        <ul class="people-grid">
            {organizers.chairs.map(chair => (
                <li class="person-card">
                    {chair.profilePic ? (
                        <img src={chair.profilePic} alt={`Profile photo of ${chair.name}`} class="person-pic" />
                    ) : (
                        <div class="person-pic person-pic-placeholder"></div>
                    )}
                    <div class="person-name">
                        {chair.website && chair.website !== '#' ? (
                            <a href={chair.website} target="_blank" rel="noopener noreferrer">{chair.name}</a>
                        ) : (
                            <span>{chair.name}</span>
                        )}
                    </div>
                    <div class="person-affil">{chair.affiliation}</div>
                </li>
            ))}
        </ul>
    </section>

</Layout>

<style>
    /* ───── Hero ─────────────────────────────────────────────── */
    .hero {
        position: relative;
        overflow: hidden;
        background-color: var(--bg-secondary);
        background-image:
            radial-gradient(circle at 12% 15%, rgba(52, 152, 219, 0.10), transparent 45%),
            radial-gradient(circle at 88% 85%, rgba(217, 119, 6, 0.07), transparent 50%);
        border: none;
        padding: 3.25rem 1.5rem 2.75rem;
        text-align: center;
        /* Break out of the 800px <main> container so the motif and background
           span the full viewport width with no surrounding frame. */
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        margin-top: 0;
        margin-bottom: 2.5rem;
    }
    /* Faint dot grid suggests data nodes / participants in a network. */
    .hero-motif {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(44, 62, 80, 0.07) 1px, transparent 1.4px);
        background-size: 26px 26px;
        mask-image: radial-gradient(ellipse at center, black 35%, transparent 80%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 35%, transparent 80%);
        pointer-events: none;
    }
    .hero-content {
        position: relative; /* sit above motif */
        max-width: 720px;
        margin: 0 auto;
    }
    .hero-eyebrow {
        margin: 0 0 0.9rem;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-dark);
    }
    .hero-title {
        margin: 0 0 0.85rem;
        font-size: clamp(2.1rem, 6vw, 3.1rem);
        line-height: 1.1;
        color: var(--text-primary);
        border-bottom: none;
        padding-bottom: 0;
        letter-spacing: -0.015em;
    }
    .hero-accent {
        color: var(--accent-dark);
    }
    .hero-tagline {
        margin: 0 auto 1.25rem;
        max-width: 600px;
        font-size: clamp(1.02rem, 2.2vw, 1.18rem);
        color: var(--text-primary);
        line-height: 1.5;
    }
    .hero-meta {
        margin: 0 0 1.5rem;
        font-size: 0.97rem;
        color: var(--text-primary);
        display: inline-flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.4rem 0.7rem;
    }
    .hero-meta a {
        color: var(--accent-dark);
        text-decoration: underline;
        text-decoration-color: rgba(41, 128, 185, 0.35);
        text-underline-offset: 3px;
    }
    .hero-sep {
        color: var(--text-secondary);
    }
    .hero-cta {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
        margin-top: 0.25rem;
    }

    /* ───── Buttons ──────────────────────────────────────────── */
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.7rem 1.4rem;
        font-size: 0.97rem;
        font-weight: 600;
        line-height: 1;
        border-radius: var(--radius-sm);
        border: 1.5px solid transparent;
        text-decoration: none;
        transition: background-color 0.15s ease, color 0.15s ease,
                    border-color 0.15s ease, transform 0.1s ease,
                    box-shadow 0.15s ease;
    }
    .btn:hover {
        text-decoration: none;
        transform: translateY(-1px);
    }
    .btn:active {
        transform: translateY(0);
    }
    .btn-primary {
        background: var(--accent-dark);
        color: #fff;
        border-color: var(--accent-dark);
        box-shadow: 0 1px 2px rgba(41, 128, 185, 0.25);
    }
    .btn-primary:hover {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
        box-shadow: 0 3px 8px rgba(52, 152, 219, 0.3);
    }
    .btn-secondary {
        background: transparent;
        color: var(--accent-dark);
        border-color: var(--accent-dark);
    }
    .btn-secondary:hover {
        background: var(--accent-tint);
        color: var(--accent-dark);
    }

    /* ───── Pull-quote ───────────────────────────────────────── */
    .pull-quote {
        margin: 2.25rem 0;
        padding: 0.4rem 0 0.4rem 1.25rem;
        border-left: 4px solid var(--accent-warm);
        font-size: clamp(1.1rem, 2.4vw, 1.3rem);
        font-style: normal;
        font-weight: 500;
        line-height: 1.45;
        color: var(--text-primary);
        background: transparent;
    }

    /* ───── Key Dates ────────────────────────────────────────── */
    .dates-grid {
        list-style: none;
        padding-left: 0;
        margin: 1.5rem 0 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
    }
    .date-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-top: 3px solid var(--accent);
        border-radius: var(--radius-sm);
        padding: 1rem 1.1rem 1.1rem;
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }
    .date-card-workshop {
        border-top-color: var(--accent-warm);
        background: linear-gradient(180deg, var(--accent-warm-soft) 0%, var(--bg-card) 60%);
    }
    .date-label {
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .date-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-primary);
        font-variant-numeric: tabular-nums;
    }
    .date-pill {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        background: var(--accent-warm);
        color: #fff;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        text-transform: uppercase;
    }
    section {
        margin-bottom: 3rem;
        padding-top: 1rem;
    }
    section h2 {
        margin-top: 0;
        margin-bottom: 1.1rem;
        padding-bottom: 0.45rem;
        display: inline-block;
        border-bottom: 3px solid transparent;
        border-image: linear-gradient(to right, var(--accent) 0%, var(--accent) 65%, var(--accent-warm) 100%) 1;
        color: var(--text-primary);
    }
    section h3 {
        margin-top: 2.25rem;
        margin-bottom: 0.7rem;
        color: var(--text-primary);
    }
    /* Shared people grid (speakers + organizers) */
    .people-grid {
        list-style: none;
        padding-left: 0;
        margin-top: 1.5rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1.5rem;
    }
    .person-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 0.25rem;
    }
    .person-pic,
    .person-pic-placeholder {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        object-fit: cover;
        background-color: var(--accent-light);
        margin-bottom: 0.85rem;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    }
    .person-name {
        font-size: 1.02rem;
        font-weight: 600;
        line-height: 1.3;
        color: var(--text-primary);
    }
    .person-name a {
        color: var(--text-primary);
    }
    .person-name a:hover {
        color: var(--accent);
        text-decoration: none;
    }
    .person-affil {
        margin-top: 0.2rem;
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.3;
    }

    /* CFP list styling */
    #cfp ul,
    #cfp ol {
        margin-left: 1.5em;
    }
    #cfp ul {
        list-style: disc;
    }
    #cfp ol {
        list-style: decimal;
    }
</style>
